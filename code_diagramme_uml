Diagramme de classe :
---------------------

@startuml

class "Compétition" as Competition {
  - id : int
  - nom : string
  - dateDebut : Date
  - dateFin : Date
  - lieu : string
  + ajouterEpreuve()
  + genererClassementGeneral()
}

class "Épreuve" as Epreuve {
  - id : int
  - type : string (Indiv/Equipe)
  - categorie : str
  - statut : bool
  + demarrer()
  + cloturer()
}

class "Participant" as Participant {
  - id : int
  - nom : string
  - nationalite : string
}

class "Athlète" as Athlete {
  - dateNaissance : Date
  - genre : string
}

class "Équipe" as Equipe {
  - nomEquipe : string
}

class "Résultat" as Resultat {
  - id : int
  - valeur : float (Temps/Score)
  - rang : int
  - statut : string (Validé/Disqualifié)
  + valider()
}

class "Officiel" as Officiel {
  - id : int
  - role : string
  + saisirResultat()
}

Competition "1" *-- "*" Epreuve : contient
Epreuve "*" -- "*" Participant : inscrit
Participant <|-- Athlete
Participant <|-- Equipe

Epreuve "1" *-- "*" Resultat : génère
Resultat "*" -- "1" Participant : appartient à
Officiel "1" ..> "*" Resultat : valide

@enduml

